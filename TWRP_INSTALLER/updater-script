#!/sbin/sh
# Fake BL Manager - TWRP Updater Script
# AdvancedInstaller format for TWRP

ui_print "Fake BL Manager v1.0.0"
ui_print "Simple, Safe, Controlled Installation"

# Check device compatibility
model=$(getprop ro.product.model)
soc=$(getprop ro.board.platform)

ui_print "Checking device compatibility..."
ui_print "Model: $model"
ui_print "SOC: $soc"

# Check if Snapdragon 8 Gen 5/8 Elite Gen 5
if echo "$soc" | grep -qi "sd8gen5\|sd8elite\|snapdragon.*8.*gen5"; then
    ui_print "Device compatible: Snapdragon 8 Gen 5/8 Elite Gen 5"
else
    ui_print "WARNING: Device may not be compatible"
    ui_print "This module is designed for Snapdragon 8 Gen 5 / 8 Elite Gen 5"
fi

# Extract and install
ui_print "Extracting and installing..."

# Get current slot
current_slot=""
case "$(getprop ro.boot.slot_suffix)" in
    _a) current_slot="_a" ;;
    _b) current_slot="_b" ;;
    *) current_slot="" ;;
esac

if [ -z "$current_slot" ]; then
    ui_print "ERROR: Cannot detect current slot"
    exit 1
fi

ui_print "Current slot: $current_slot"
ui_print "Target slot: _b (or _a if _b)"

# Extract ABL
ui_print "Extracting ABL..."
if [ -f "/dev/block/by-name/abl$current_slot" ]; then
    mkdir -p /tmp/fake_bl
    extractfv -o /tmp/fake_bl -v "/dev/block/by-name/abl$current_slot"
    
    if [ -f "/tmp/fake_bl/LinuxLoader.efi" ]; then
        ui_print "ABL extracted successfully"
    else
        ui_print "ERROR: ABL extraction failed"
        exit 1
    fi
else
    ui_print "ERROR: ABL partition not found"
    exit 1
fi

# Patch ABL
ui_print "Patching ABL..."
patch_abl /tmp/fake_bl/LinuxLoader.efi /tmp/fake_bl/patched.efi

if [ ! -f "/tmp/fake_bl/patched.efi" ]; then
    ui_print "ERROR: Patching failed"
    exit 1
fi

# Check for GBL error
if grep -q "Warning: Failed to patch ABL GBL" /tmp/fake_bl/patch.log; then
    ui_print "ERROR: GBL exploit not found"
    ui_print "This device may need ABL downgrade first"
    exit 1
fi

ui_print "Patch successful"

# Inject superfastboot if available
if [ -f "/tmp/fake_bl/loader.elf" ]; then
    ui_print "Injecting superfastboot..."
    elf_inject /tmp/fake_bl/loader.elf /tmp/fake_bl/patched.efi /tmp/fake_bl/injected.dll
    if [ -f "/tmp/fake_bl/injected.dll" ]; then
        GenFw -e UEFI_APPLICATION -o /tmp/fake_bl/patched.efi /tmp/fake_bl/injected.dll
        ui_print "Injection successful"
    fi
fi

# Flash to efisp
ui_print "Flashing to efisp..."
blockdev --setrw /dev/block/by-name/efisp
dd if=/tmp/fake_bl/patched.efi of=/dev/block/by-name/efisp bs=4M conv=fsync
sync

ui_print "Installation complete"
ui_print "Please reboot to system"

# Cleanup
rm -rf /tmp/fake_bl

exit 0
